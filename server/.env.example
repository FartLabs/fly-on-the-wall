# Server
PORT=8080
LOG_LEVEL=info
BASE_URL=http://localhost:8080
ALLOWED_ORIGINS=*

# Database
DATABASE_DRIVER=sqlite
DATABASE_URL=file:./data/dev.db

# Sessions & Auth
SESSION_TTL=720h
BCRYPT_COST=12
CSRF_SECRET=change-me-in-production-32chars!
COOKIE_SECURE=false
COOKIE_DOMAIN=

# S3-compatible storage 
S3_ENABLED=true
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=flyonthewall
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Stripe 
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Premium mode: "stripe", "admin_override", "all_premium"
# Use "all_premium" for self-hosted (everyone gets premium features)
PREMIUM_MODE=all_premium

# Worker type: "local" or "remote"
WORKER_TYPE=local

# Admin bootstrap (optional but recommended for prod)
# If both are set and no admin users exist, an admin account is created on startup.
# Best to use a very strong password!
ADMIN_USERNAME=
ADMIN_PASSWORD=
